<% content_for :extern_css do %>
  <link rel="stylesheet" href="/css/home/header.css">
  <link rel="stylesheet" href="/css/home/footer.css">
  <link rel="stylesheet" href="/css/home/landing.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
<% end %>

<% content_for :extern_js do %>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<% end %>

<%= render "home/partials/header" %>

<div class="home-main-layout">
  <aside class="sidebar-keywords" data-controller="sidebar">
    <div data-sidebar-target="sidebar" class="filter-sidebar" id="filter-sidebar">
      <div class="filter-container" id="filter-container">
        <div class="filter-title-row">
          <h4 class="filter-title">Mots-clés populaires</h4>
          <button class="filter-toggle-btn" id="filter-toggle-btn" aria-label="Afficher/masquer les mots-clés" data-action="click->sidebar#toggle">
            <svg width="14" height="20" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7.4 4.59961L2 9.99961L7.4 15.3996" stroke="#9DADAB" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M12.8008 1V19" stroke="#9DADAB" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <div class="keywords-list" id="keywords-list">
          <div class="filter-keyword"><span class="filter-keyword-name">export</span> <span class="filter-keyword-count">+950</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">agroalimentaire</span> <span class="filter-keyword-count">+579</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">transformation</span> <span class="filter-keyword-count">+348</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">artisanat</span> <span class="filter-keyword-count">+286</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">Thiès</span> <span class="filter-keyword-count">+203</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">Fatick</span> <span class="filter-keyword-count">+186</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">Louga</span> <span class="filter-keyword-count">+185</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">Sédhiou</span> <span class="filter-keyword-count">+173</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">Kaffrine</span> <span class="filter-keyword-count">+160</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">énergie</span> <span class="filter-keyword-count">+156</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">numérique</span> <span class="filter-keyword-count">+153</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">industriel</span> <span class="filter-keyword-count">+147</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">Kédougou</span> <span class="filter-keyword-count">+140</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">industrie</span> <span class="filter-keyword-count">+139</span></div>
          <div class="filter-keyword"><span class="filter-keyword-name">recyclage</span> <span class="filter-keyword-count">+127</span></div>
        </div>
      </div>
    </div>
  </aside>
  <section class="main-content">
    <div class="view-switcher-wrapper" data-controller="view-switcher">
      <div class="search-bar-row">
        <div class="search-bar">
          <input type="text" class="search-input" placeholder="Rechercher par mot-clé, secteur d'activité, ...">
          <span class="search-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15.649 15.649C18.5299 12.7681 18.5299 8.09718 15.649 5.21627C12.7681 2.33536 8.09725 2.33536 5.21635 5.21627C2.33544 8.09718 2.33544 12.7681 5.21635 15.649C8.09725 18.5299 12.7681 18.5299 15.649 15.649Z" stroke="#9DADAB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M22.6036 22.6045L15.6484 15.6494" stroke="#9DADAB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
        <div class="view-switcher" data-view-switcher-target="dropdown">
          <button class="view-btn" id="view-btn" type="button" data-action="click->view-switcher#toggleDropdown">
            <span class="view-btn-icon" data-view-switcher-target="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="23" viewBox="0 0 28 23" fill="none">
                <path d="M1 20.9838L3.20268 9.45143L8.47243 6.5459L14.0693 9.45143L19.6582 6.5459L24.9266 9.45143L27 20.7253L20.5212 18.018L14.0761 20.9838L7.56496 17.9751L1 20.9838Z" stroke="#004439" stroke-width="1.5" stroke-miterlimit="10"/>
