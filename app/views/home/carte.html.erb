<% content_for :title, "Carte des Opportunités - Yembal" %>
<% content_for :head do %>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Explorez les opportunités d'investissement au Sénégal avec notre carte interactive optimisée">
<% end %>

<div class="yembal-layout">
  <!-- Sidebar des filtres -->
  <aside class="filters-sidebar" 
         data-controller="filters"
         data-filters-stats-endpoint-value="/api/v1/opportunities/stats"
         data-filters-search-endpoint-value="/api/v1/opportunities/search"
         data-filters-debounce-delay-value="300">
    
    <!-- Header -->
    <div class="filters-header">
      <h1 class="filters-title">Opportunités d'Investissement</h1>
      <p class="filters-subtitle">Explorez les projets au Sénégal</p>
    </div>

    <!-- Recherche -->
    <div class="search-section">
      <div class="search-input-wrapper">
        <div class="search-icon">🔍</div>
        <input type="text" 
               class="search-input" 
               placeholder="Rechercher une opportunité..."
               data-filters-target="searchInput">
      </div>
    </div>

    <!-- Compteurs globaux -->
    <div class="counters-section" data-filters-target="counters">
      <div class="global-stats">
        <div class="stat-item">
          <span class="stat-label">Total des opportunités</span>
          <span class="stat-value total-count">-</span>
        </div>
      </div>
    </div>

    <!-- Filtres par secteur -->
    <div class="filter-section">
      <div class="filter-section-title">
        <span>Secteurs d'activité</span>
        <span class="filter-section-count" id="sectors-count">-</span>
      </div>
      <div class="filter-list" data-filters-target="sectorList">
        <!-- Les secteurs seront chargés dynamiquement -->
        <div class="loading-placeholder">Chargement des secteurs...</div>
      </div>
    </div>

    <!-- Filtres par tags populaires -->
    <div class="filter-section">
      <div class="filter-section-title">
        <span>Mots-clés populaires</span>
        <span class="filter-section-count" id="tags-count">-</span>
      </div>
      <div class="filter-list" data-filters-target="tagsList">
        <!-- Les tags seront chargés dynamiquement -->
        <div class="loading-placeholder">Chargement des tags...</div>
      </div>
    </div>

    <!-- Filtres par localisation -->
    <div class="filter-section">
      <div class="filter-section-title">
        <span>Localisations</span>
        <span class="filter-section-count" id="locations-count">-</span>
      </div>
      <div class="filter-list" data-filters-target="locationsList">
        <!-- Les localisations seront chargées dynamiquement -->
        <div class="loading-placeholder">Chargement des localisations...</div>
      </div>
    </div>

    <!-- Actions -->
    <div class="filter-actions">
      <button class="reset-filters-btn" 
              data-action="click->filters#resetFilters">
        🔄 Réinitialiser les filtres
      </button>
    </div>

    <!-- Loading spinner -->
    <div class="loading-spinner" data-filters-target="loadingSpinner">
      Chargement des données...
    </div>
  </aside>

  <!-- Zone de contenu principale avec la carte -->
  <main class="content-area">
    <div class="map-container"
         data-controller="map"
         data-map-center-value="[14.6928, -17.4467]"
         data-map-zoom-value="7"
         data-map-api-endpoint-value="/api/v1/opportunities/viewport">
      
      <!-- Conteneur de la carte -->
      <div class="map-wrapper">
        <div id="map" data-map-target="container"></div>
        
        <!-- Overlay de chargement -->
        <div class="map-loading-overlay" 
             data-map-target="loadingOverlay"
             style="display: flex;">
          Initialisation de la carte...
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Styles additionnels pour cette page -->
<style>
  body {
    margin: 0;
    padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    overflow: hidden;
  }

  .loading-placeholder {
    padding: 12px 0;
    color: #9CA3AF;
    font-size: 14px;
    text-align: center;
    font-style: italic;
  }

  .global-stats {
    background-color: #F9FAFB;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 24px;
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .stat-label {
    font-size: 14px;
    color: #6B7280;
    font-weight: 500;
  }

  .stat-value {
    font-size: 18px;
    font-weight: 600;
    color: #3B605A;
  }

  .counters-section {
    margin-bottom: 24px;
  }

  /* Animation de chargement */
  .loading-placeholder {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Responsive amélioré */
  @media (max-width: 768px) {
    .yembal-layout {
      flex-direction: column;
    }
    
    .filters-sidebar {
      order: 2;
      width: 100%;
      height: auto;
      max-height: 40vh;
      border-radius: 16px 16px 0 0;
      border-right: none;
      border-top: 1px solid #E5E7EB;
    }
    
    .content-area {
      order: 1;
      height: 60vh;
    }
    
    .map-container {
      height: 100%;
    }
  }
</style>

<!-- Script pour tester la communication entre contrôleurs -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 Page carte chargée');
    
    // Écouter les événements personnalisés
    document.addEventListener('map:markerClick', function(event) {
      console.log('📍 Marqueur cliqué:', event.detail.opportunity);
    });
    
    document.addEventListener('filters:filterChange', function(event) {
      console.log('🔍 Filtres changés:', event.detail.filters);
    });
    
    document.addEventListener('filters:searchResults', function(event) {
      console.log('🔎 Résultats de recherche:', event.detail.opportunities);
    });
  });
</script> 